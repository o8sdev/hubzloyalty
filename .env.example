# Copy to .env and fill in real values.

# SQLite for local dev. For production swap to PostgreSQL, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/loyaltycrm"
DATABASE_URL="file:./dev.db"

# 32+ char random secret used to sign session JWTs.
SESSION_SECRET=""

# Public base URL of the app (used to build QR-code review links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

