# Copy to .env and fill in real values.

# PostgreSQL (Supabase). DATABASE_URL goes through the transaction pooler
# (serverless-safe); DIRECT_URL is a session-mode connection for migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase Auth (identities, sessions, reset emails). URL + anon key are
# public; the service-role key is server-only — never expose it client-side.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Public base URL of the app (used to build QR-code review links + email links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend email. Unset = dev mode: emails are logged to the console and the
# EmailLog table instead of sent. MAIL_FROM must be a verified Resend domain
# in production (defaults to onboarding@resend.dev).
# RESEND_API_KEY=""
# MAIL_FROM="LoyaltyCRM <alerts@yourdomain.com>"

# Shared secret protecting cron endpoints (weekly digest + daily loyalty jobs:
# birthday bonuses & points expiry). On Vercel, cron invocations send it
# automatically as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=""

# Rate limiting enforces only in production by default (local dev shares one
# IP bucket and trips limits during manual testing). Set "true" to force it
# on in dev, or "false" to disable it in production (not recommended).
# RATE_LIMIT_ENABLED=""

# Platform admin account, seeded by prisma/seed.ts (login goes to /admin).
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- Phase 4+ (not required yet) ---
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# ANTHROPIC_API_KEY=""
