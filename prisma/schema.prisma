// LoyaltyCRM data model.
// Runs on PostgreSQL (Supabase). DATABASE_URL goes through the transaction
// pooler (serverless-safe); DIRECT_URL is a session-mode connection used by
// prisma migrate. Enum-like fields stay Strings with the allowed values
// noted inline; they are validated at the API layer (src/lib/validation.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Business {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique // public handle used in QR review URLs: /r/[slug]
  logoUrl         String?
  address         String?
  phone           String?
  email           String?
  website         String?
  googleReviewUrl String?
  socialLinks     String? // JSON string: { instagram?, facebook?, tiktok? }
  timezone        String   @default("UTC")

  // Per-business loyalty program configuration. Thresholds are the visit
  // counts at which a customer reaches each tier (BRONZE is below Silver).
  // Changing these recalculates every customer's stored tier (see
  // /api/business/loyalty).
  pointsPerVisit  Int @default(10)
  silverThreshold Int @default(5)
  goldThreshold   Int @default(10)
  vipThreshold    Int @default(20)

  // Owner notification preferences (Phase 2 emails).
  notifyComplaints   Boolean @default(true)
  notifyWeeklyDigest Boolean @default(true)

  // Welcome reward for first-time funnel completers. COMPLIANCE: granted for
  // joining the guest list (form completion), never for the review/rating —
  // copy must never condition the gift on a review (Google policy, FTC 465).
  welcomeRewardEnabled    Boolean @default(false)
  welcomeRewardText       String? // e.g. "A free espresso — on us"
  welcomeRewardExpiryDays Int     @default(14)
  // Owner-set cost of the welcome gift (integer cents) — frozen onto each
  // grant so the loyalty ledger can total the value handed out (accounting).
  welcomeRewardValueCents Int     @default(0)

  // Visit verification policy: points credit ONLY when staff confirm a
  // check-in code (human approval on every earning visit). Cooldown/cap
  // bound how often a guest can even mint a code; feedback is never gated.
  earnCooldownHours Int     @default(6) // 0 = no cooldown
  maxEarnPerDay     Int     @default(2)
  askTableNumber    Boolean @default(false) // waiter venues: capture table #

  // Automatic loyalty mechanics (no staff action; each posts to PointsLedger).
  // Birthday bonus: awarded once per year on the guest's birthday (daily cron).
  birthdayBonusEnabled Boolean @default(false)
  birthdayBonusPoints  Int     @default(0)
  // Tier-up bonus: awarded once when a visit promotes the guest to a new tier.
  tierBonusEnabled      Boolean @default(false)
  tierBonusSilverPoints Int     @default(0)
  tierBonusGoldPoints   Int     @default(0)
  tierBonusVipPoints    Int     @default(0)
  // Points expire after this many months of inactivity (daily cron). 0 = never.
  pointsExpiryMonths Int @default(0)

  // Max STAFF members (owner excluded) the owner can invite. Defaults to 1;
  // only a platform admin can raise it per business.
  staffLimit Int @default(1)

  // Guest-app discovery profile. `listed` is opt-in: the business only appears
  // in the consumer directory once the owner turns it on. Lat/lng power a
  // "near me" sort. All nullable so existing rows need no backfill.
  listed        Boolean @default(false)
  category      String? // "Coffee" | "Restaurant" | "Bakery" | "Bar" | ...
  description   String?
  city          String?
  latitude      Float?
  longitude     Float?
  coverImageUrl String?

  // Set by a platform admin to suspend the business: blocks member logins
  // and returns 404 on the public funnel. Null = active.
  suspendedAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users        User[]
  customers    Customer[]
  visits       Visit[]
  reviews      Review[]
  rewards      Reward[]
  redemptions  Redemption[]
  campaigns    Campaign[]
  rewardClaims RewardClaim[]
  checkins     Checkin[]
  auditLogs    AuditLog[]
  photos       BusinessPhoto[]
  ledger       PointsLedger[]
}

// Gallery photos shown on the guest venue page. The MAIN photo is
// Business.coverImageUrl and the LOGO is Business.logoUrl; these are the extra
// gallery shots. The count is capped in the upload API (not the schema).
model BusinessPhoto {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  position   Int      @default(0) // display order, low first
  createdAt  DateTime @default(now())

  @@index([businessId, position])
}

// Append-only trail of meaningful actions across the platform. Owners see
// their own team's actions (Activity page); platform admins see everything
// (filterable). actorEmail/actorRole are denormalized so a row survives the
// user being deleted and stays filterable without a join.
model AuditLog {
  id          String    @id @default(cuid())
  businessId  String? // null for platform-level actions not tied to a business
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actorUserId String? // domain User.id; null if the actor is gone/system
  actorEmail  String // who acted (denormalized)
  actorRole   String // OWNER | ADMIN | STAFF | PLATFORM_ADMIN
  action      String // dotted key, e.g. "checkin.confirm", "settings.loyalty"
  summary     String // human-readable one-liner shown in the UI
  targetType  String? // optional: customer | checkin | review | business | user
  targetId    String?
  ip          String?
  createdAt   DateTime  @default(now())

  @@index([businessId, createdAt])
  @@index([actorEmail, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// Domain profile for an authenticated person. Identity (credentials, email
// verification, sessions, reset emails) lives in Supabase Auth (auth.users);
// authId links the two. Tenancy/authorization facts (businessId, role,
// isPlatformAdmin, mustChangePassword) are owned HERE and mirrored into
// auth.users.app_metadata so sessions carry them without a DB read — any
// write to these fields must go through syncAuthClaims() (src/lib/supabase.ts).
model User {
  id           String    @id @default(cuid())
  // auth.users.id (UUID). Nullable only because rows are created before the
  // auth user in some flows; enforced present by the application.
  authId       String?   @unique
  email        String    @unique
  name         String
  role         String    @default("OWNER") // OWNER | STAFF | ADMIN
  // Platform operator (systems admin): full access to /admin across all
  // tenants. Independent of the per-business role; businessId may be null.
  isPlatformAdmin Boolean @default(false)
  // Set when the account was provisioned with a one-time password (invite-only
  // onboarding): the user must set their own password at first login before
  // they can use the app.
  mustChangePassword Boolean @default(false)
  businessId   String?
  business     Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Consumer account: a guest who installed the app, signs in with email, and
// engages MANY businesses. Credentials/verification live in Supabase Auth
// (auth.users); authId links. A Guest is NOT a tenant — it owns no businessId.
// Its relationship with each business is a Customer row (Customer.guestId), so
// one Guest maps to many per-business memberships and the existing loyalty /
// check-in / review engine is reused unchanged. Self-registration is a separate
// door from invite-only business onboarding (see CLAUDE.md).
model Guest {
  id               String   @id @default(cuid())
  authId           String?  @unique // auth.users.id (UUID)
  email            String   @unique
  name             String
  avatarUrl        String?
  // Platform-level marketing consent; per-business consent stays on Customer.
  marketingConsent Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships Customer[] // one per business engaged
  reviews     Review[]   // first-party (in-app) reviews authored

  @@index([email])
}

model Customer {
  id               String    @id @default(cuid())
  businessId       String
  business         Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  // When set, this per-business record belongs to a registered app Guest — the
  // guest's loyalty membership here. Null for walk-ins / QR / imports.
  guestId          String?
  guest            Guest?    @relation(fields: [guestId], references: [id], onDelete: SetNull)
  firstName        String
  lastName         String?
  phone            String?
  email            String?
  birthday         DateTime?
  marketingConsent Boolean   @default(false)
  totalVisits      Int       @default(0)
  totalSpendCents  Int       @default(0) // money stored as integer cents
  loyaltyPoints    Int       @default(0)
  tier             String    @default("BRONZE") // BRONZE | SILVER | GOLD | VIP
  lastVisitAt      DateTime?
  tags             String    @default("") // comma-separated, e.g. "regular,vegan"
  notes            String?
  source           String    @default("MANUAL") // MANUAL | QR | IMPORT
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  visits       Visit[]
  reviews      Review[]
  redemptions  Redemption[]
  rewardClaims RewardClaim[]
  checkins     Checkin[]
  ledger       PointsLedger[]

  // At most one membership per guest per business (nulls stay distinct, so
  // walk-ins are unaffected). This is the find-or-create key when a guest scans.
  @@unique([businessId, guestId])
  @@index([businessId, lastVisitAt])
  @@index([businessId, phone])
  @@index([businessId, tier])
  @@index([businessId, createdAt])
  @@index([guestId])
}

model Visit {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amountCents  Int      @default(0)
  pointsEarned Int      @default(0)
  note         String?
  visitedAt    DateTime @default(now())

  @@index([businessId, visitedAt])
  @@index([customerId])
}

// One row per QR review-funnel interaction. The funnel is UNGATED: every
// rating sees both the public Google option and the private note option.
// Rows with rating <= 3 additionally surface in the feedback inbox
// (status NEW until the owner resolves them).
model Review {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // Author when the review came from a signed-in app guest (channel APP).
  guestId       String?
  guest         Guest?    @relation(fields: [guestId], references: [id], onDelete: SetNull)
  // FUNNEL = public QR funnel (owner's private complaint inbox); APP =
  // first-party review written in the guest app, shown publicly in Discover.
  // COMPLIANCE: neither channel is gated and neither ever awards points.
  channel       String    @default("FUNNEL")
  rating        Int // 1-5
  comment       String?
  clickedGoogle Boolean   @default(false)
  status        String    @default("NEW") // NEW | RESOLVED
  // When the rating<=3 complaint alert email went out (dedupe guard).
  alertSentAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, status, rating])
  @@index([businessId, channel, createdAt])
}

// A redeemable reward in a business's loyalty catalog. `pointsCost` is what
// the guest spends; `costValueCents` is what it costs the owner (COGS) —
// frozen onto each Redemption so accounting reports survive later edits.
model Reward {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  pointsCost     Int
  costValueCents Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  redemptions Redemption[]

  @@index([businessId, active])
}

// A points redemption — the guest spent points on a reward. The deduction is
// posted to PointsLedger (type REDEEM) in the same transaction. rewardName /
// pointsSpent / valueCents are FROZEN at redemption so the record is immutable
// even if the reward is later edited or deleted (rewardId → SetNull).
//
// Two lifecycles share this table:
//   • STAFF-instant (born CONFIRMED, no code): staff redeem for a guest at the
//     counter — points move immediately.
//   • GUEST self-redeem (born PENDING, carries a bearer `code`): a guest mints
//     a code from their wallet; points DO NOT move yet. Staff confirm the code
//     at the counter, which flips it CONFIRMED and posts the REDEEM ledger row.
// This mirrors the welcome-gift RewardClaim flow. Expiry of a PENDING code is
// DERIVED at read time from expiresAt (no cron); at most one PENDING code per
// customer (partial unique index in the migration).
model Redemption {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rewardId         String?
  reward           Reward?  @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rewardName       String // frozen
  pointsSpent      Int // frozen
  valueCents       Int      @default(0) // frozen cost value
  // Guest self-redeem bearer code (normalized, no dashes); null for staff-instant.
  code             String?  @unique
  status           String   @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED | EXPIRED
  expiresAt        DateTime? // set on PENDING codes; expiry derived at read time
  redeemedByUserId String? // staff/owner who handed it over (null until confirmed)
  redeemedAt       DateTime? // when confirmed/handed over; null while PENDING
  createdAt        DateTime  @default(now())

  @@index([businessId, redeemedAt])
  @@index([customerId])
  @@index([businessId, status, createdAt])
}

model Campaign {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  type       String // WINBACK | BIRTHDAY | VIP | FIRST_VISIT | MANUAL
  channel    String   @default("SMS") // SMS | EMAIL | WHATSAPP
  message    String
  status     String   @default("DRAFT") // DRAFT | ACTIVE | PAUSED | SENT
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  recipients CampaignRecipient[]

  @@index([businessId, status])
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  status     String    @default("PENDING") // PENDING | SENT | FAILED
  sentAt     DateTime?

  @@index([campaignId, status])
}

// Inbound "request a demo" leads from the marketing site (the app is
// invite-only; there is no self-serve registration). The platform admin works
// them NEW -> CONTACTED -> CONVERTED (business provisioned) or DISMISSED.
model DemoRequest {
  id                  String   @id @default(cuid())
  businessName        String
  contactName         String
  email               String
  phone               String?
  message             String?
  status              String   @default("NEW") // NEW | CONTACTED | CONVERTED | DISMISSED
  adminNotes          String?
  convertedBusinessId String? // set when the admin registers the business from this request
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

// Audit trail of every outbound email. status DEV_LOGGED means no
// RESEND_API_KEY was configured, so the message was logged instead of sent.
model EmailLog {
  id         String   @id @default(cuid())
  businessId String? // null for platform-level mail (e.g. password resets)
  to         String
  subject    String
  kind       String // COMPLAINT_ALERT | WEEKLY_DIGEST | PASSWORD_RESET | TEST
  status     String // SENT | FAILED | DEV_LOGGED
  error      String?
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([kind, createdAt])
  @@index([createdAt])
}

// A granted, code-bearing reward (currently only kind WELCOME: the one-time
// gift for first-time funnel completers). Distinct from the Phase 3
// Reward/Redemption catalog: a claim is granted (no points cost), carries a
// bearer code shown at the counter, and expires. Expiry is DERIVED at read
// time from expiresAt — no cron flips statuses.
model RewardClaim {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind       String   @default("WELCOME")
  code       String   @unique // short unambiguous bearer code, stored normalized (no dashes)
  rewardText String // frozen at grant time — owner may change the config later
  valueCents Int      @default(0) // frozen cost of the gift for accounting (see PointsLedger)
  status     String   @default("PENDING") // PENDING | REDEEMED
  expiresAt  DateTime?
  redeemedAt DateTime?
  redeemedByUserId String? // which staff/owner account confirmed it
  createdAt  DateTime @default(now())

  // One welcome reward per customer, guaranteed at the schema level.
  @@unique([customerId, kind])
  @@index([businessId, status, createdAt])
}

// Append-only financial ledger of every loyalty movement — the source of
// truth for a guest's points. `Customer.loyaltyPoints` is a CACHE that must
// always equal SUM(delta) for that customer; every earn / redeem / bonus /
// expiry writes a row here in the SAME transaction that moves the cache, so
// the two never drift. Rows are NEVER updated or deleted — a correction is a
// new REVERSAL row. `valueCents` freezes the cash value of the movement (e.g.
// the cost of a reward handed over) so accounting reports survive later edits
// to the reward. Non-points events (a free-item gift) carry delta 0 + a value.
model PointsLedger {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  // EARN | REDEEM | WELCOME_BONUS | BIRTHDAY_BONUS | TIER_BONUS | EXPIRE | MANUAL_ADJUST | REVERSAL
  type            String
  delta           Int // signed points (+earned, -spent/expired; 0 for item gifts)
  balanceAfter    Int // the customer's cached balance immediately after this entry
  valueCents      Int      @default(0) // frozen cash value of the movement
  sourceType      String? // VISIT | REDEMPTION | REWARD_CLAIM | CHECKIN | CAMPAIGN | MANUAL
  sourceId        String?
  createdByUserId String? // staff/owner who confirmed it; null for automatic/system
  note            String?
  createdAt       DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([customerId, createdAt])
  @@index([businessId, type, createdAt])
}

// A pending visit awaiting human approval. The funnel mints one per earning
// scan (subject to the business's cooldown/cap); staff confirm the guest's
// code at the till, at the table, or from the pending queue — confirmation
// is what creates the Visit and credits points. PENDING entries expire
// (derived from expiresAt at read time — no cron flips statuses).
model Checkin {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reviewId   String?  @unique // the funnel completion that minted it
  code       String   @unique // short bearer code, stored normalized
  tableNumber String? // waiter venues (self-reported, human-verified)
  status     String   @default("PENDING") // PENDING | CONFIRMED
  confirmedByUserId String?
  confirmedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([businessId, status, createdAt])
  @@index([customerId, status])
}

// Fixed-window rate limiting for public endpoints. One row per (route, ip)
// bucket; incremented atomically with INSERT ... ON CONFLICT (src/lib/ratelimit.ts).
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  windowEnd DateTime
}
